{
  "sheet_file": "lapeg.png",
  "symbol_size": 160,
  "cols": 10,
  "rows": 3,
  "writing_mode": "horizontal",
  "spacing": { "x": 10, "y": 10 },
  "trim": { "left": 20, "right": 20, "top": 0, "bottom": 0 },
  "overlay": {
    "enabled": true,
    "roots": ["i", "u", "e", "a", "o"],
    "blockers": [],
    "offset_x": 0,
    "offset_y": 0
  },
  "tokenizer": { "separator": " " },
  "description": "Lapag language character symbols",
  "notes": "Silencio en [0,0]. Vocales sobreponen sobre consonante o silencio. Separador de palabra en ultima posicion. Usar hoja estandar lapeg.png.",
  "root_mapping": {
    "_": [0, 0],
    "i":    [0, 1],
    "u":    [0, 2],
    "e":    [0, 3],
    "a":    [0, 4],
    "o":    [0, 5],
    "sh":   [0, 6],
    "d":    [0, 7],
    "t":    [0, 8],
    "s":    [0, 9],
    "k":    [1, 0],
    "r":    [1, 1],
    "l":    [1, 2],
    "n":    [1, 3],
    "m":    [1, 4],
    "j":    [1, 5],
    "g":    [1, 6],
    "b":    [1, 7],
    "f":    [1, 8],
    "y":    [1, 9],
    "p":    [2, 0],
    "x":    [2, 1],
    "?":    [2, 2],
    " ":    [2, 3]
  }
}
